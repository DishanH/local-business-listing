{
  "_readme": [
    "REFERENCE + SAMPLE for generating bulk test businesses.",
    "Hand this whole file to your generation service and ask it to output an ARRAY",
    "of business objects shaped like the entries in `samples`, choosing slugs ONLY",
    "from `allowed_values`. Then save that array as its own .json file and run:",
    "  npx tsx supabase/seed-businesses.ts supabase/seed-businesses.generated.json",
    "Do NOT invent new category, subcategory, filter, or city slugs — the importer",
    "looks each one up by slug and will skip/fail rows that reference a missing slug.",
    "`category_slug`, `city_slug`, `name`, `slug`, and `status` are required; everything",
    "else is optional. `slug` must be globally unique (kebab-case)."
  ],

  "field_reference": {
    "slug": "Required. Unique, kebab-case identifier, e.g. 'copper-fork-cafe-hamilton'.",
    "name": "Required. Display name.",
    "tagline": "Short one-liner.",
    "description": "1-3 sentences.",
    "category_slug": "Required. MUST be a top-level key in allowed_values.categories.",
    "subcategory_slug": "Optional. MUST be one of that category's subcategories in allowed_values.categories[category_slug].",
    "status": "Required. One of allowed_values.status. Use 'published' so it shows on the site.",
    "price_level": "Integer 1-4 (or omit). 1=$, 4=$$$$.",
    "email": "Dummy address is fine, e.g. 'hello@example.com'.",
    "phone": "Dummy Ontario number. Use the reserved 555-01xx range: '+1-519-555-0142'.",
    "website": "Dummy URL is fine.",
    "address_line1": "Ontario street address.",
    "address_line2": "Optional (suite/unit) or null.",
    "city_slug": "Required. MUST be an existing slug in allowed_values.cities.existing (only 'brantford' is Ontario by default — see allowed_values.cities.ontario_optional_add_first to add more first).",
    "postal_code": "Canadian format 'A1A 1A1'.",
    "lat": "Latitude (double). Ontario is roughly 42-46 N.",
    "lng": "Longitude (double). Ontario is roughly -74 to -83 W (negative).",
    "cover_image_url": "Card/hero image. Placeholder OK, e.g. 'https://picsum.photos/seed/<slug>/1200/800'.",
    "is_featured": "Boolean. Keep most false; a few true.",
    "avg_rating": "numeric(2,1): one decimal, keep 3.5-5.0. Denormalized; triggers overwrite it once real reviews exist.",
    "review_count": "Integer.",
    "keywords": "Array of lowercase search terms.",
    "published_at": "ISO timestamp; set when status is 'published'.",
    "created_by": "Keep null for seed data.",
    "owners": "Array of { profile_id, role }. Assign ONE owner per business, ALTERNATING between the two ids in allowed_values.owner_profile_ids (roughly half to each). Use role 'owner'. profile_id must be an existing profiles.id; null profile_ids are skipped by the importer.",
    "filter_slugs": "Array of amenity slugs. Use allowed_values.filters_global plus, if applicable, allowed_values.filters_by_category[category_slug]. Unknown slugs are silently ignored.",
    "images": "Gallery photos. Each { url, alt_text, sort_order }.",
    "hours": "Array of 0-7 rows. day_of_week 0-6 (see allowed_values.day_of_week). open_minute/close_minute are minutes past midnight (0-1440); e.g. 9:00 AM = 540, 10:30 PM = 1350. Use null/null (or omit the day) for closed.",
    "offering_sections": "Menu/products grouped into sections; each section has offerings. price_cents is an integer (1295 = $12.95); use price_label for non-numeric prices ('Market price').",
    "specials": "Weekly/limited deals. day_of_week optional (omit/null = any day).",
    "posts": "News & offers. type is one of allowed_values.post_type."
  },

